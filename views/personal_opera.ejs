    <script>

        let isSubmitting = false;


        let persona = {}; // Variable para almacenar la persona seleccionada

        // Mostrar el spinner mientras se cargan las personas
        document.getElementById('loading-personas').style.display = 'block';


        // Obtener todas las personas

        function cargarPersonalActualizado() {
            fetch('/api/personas')
                .then(response => response.json())
                .then(data => {
                    document.getElementById('loading-personas').style.display = 'none';
                    const personasList = document.getElementById('personas-list');

                    // Asegurarse de que el contenedor esté vacío antes de agregar los nuevos elementos
                    personasList.innerHTML = ''; // Limpiar la lista antes de agregar elementos

                    // Recorrer los datos de las personas y agregar los elementos <li>
                    data.personas.forEach(persona => {
                        console.log(`Persona ID: ${persona.id}`);
                        // Crear el contenido HTML del <li> con el atributo persona_id
                        const liHTML = `
                    <li class="selected-person" data-persona_id="${persona.id}" onclick="verDetalles(${persona.id})">
                        ${persona.nombres} ${persona.apellidos}
                    </li>
                `;
                        // Insertar el contenido HTML directamente en el contenedor
                        personasList.insertAdjacentHTML('beforeend', liHTML);
                    });
                })
                .catch(error => {
                    console.error('Error obteniendo las personas:', error);
                    document.getElementById('loading-personas').textContent = 'Error al cargar las personas';
                });
        }

        cargarPersonalActualizado()

        // Ver los detalles de una persona
        function verDetalles(idPersona) {

            console.log("ID Persona recibido:", idPersona);
            const documentsList = document.getElementById('documents-list');

            const documentModal = document.getElementById('documents-modal')

            documentModal.style.display = 'none';

            // Mostrar el spinner mientras se cargan los detalles
            document.getElementById('persona-info').innerHTML = '<div class="loading-spinner"> </div>';

            const baseUrl = "https://tjbtusdhxjczmpvwzqzx.supabase.co/storage/v1/object/public/personal-docs/";

            fetch(`/api/personas/${idPersona}`)
                .then(response => response.json())
                .then(data => {
                    persona = data;
                    const linkImg = baseUrl + persona.foto_url;
                    document.getElementById('persona-details').style.display = 'block';

                    // Rellenar los campos de edición con la información de la persona
                    document.getElementById('nombres').value = persona.nombres;
                    document.getElementById('apellidos').value = persona.apellidos;
                    document.getElementById('cedula').value = persona.cedula;
                    document.getElementById('fecha_ingreso').value = persona.fecha_ingreso;
                    document.getElementById('fecha_terminacion').value = persona.fecha_terminacion;
                    document.getElementById('tiempo_trabajo').value = persona.tiempo_trabajo;
                    document.getElementById('cargo').value = persona.cargo;
                    document.getElementById('eps').value = persona.eps;
                    document.getElementById('arl').value = persona.arl;
                    document.getElementById('caja_compensacion').value = persona.caja_compensacion;
                    document.getElementById('fondo_pension').value = persona.fondo_pension;
                    document.getElementById('correo').value = persona.correo;
                    document.getElementById('celular').value = persona.celular;
                    document.getElementById('direccion').value = persona.direccion;
                    document.getElementById('foto_url').value = persona.foto_url;

                    document.getElementById('persona-info').innerHTML = `
                    <img src="${linkImg}" alt="Foto" width="100">
                `;
                })
                .catch(error => {
                    console.error('Error obteniendo los detalles de la persona:', error);
                    document.getElementById('persona-info').innerHTML = 'Error al cargar los detalles';
                });
        }

      // Variable para controlar el estado de envío de la foto
let isUploadingPhoto = false;

// Subir foto optimizada
document.getElementById('foto-upload-form').addEventListener('submit', function (e) {
    e.preventDefault();

    // Comprobar si ya se está subiendo una foto
    if (isUploadingPhoto) {
        return; // Si ya se está subiendo, no hacer nada
    }

    const fileInput = document.querySelector('input[type="file"]');
    const file = fileInput.files[0];

    if (file) {
        // Bloquear la interfaz mientras se sube la foto
        isUploadingPhoto = true; // Establecer el estado de carga
        disableForm(true); // Deshabilitar el formulario

        // Mostrar la superposición para oscurecer la interfaz
        const overlay = document.createElement('div');
        overlay.classList.add('overlay');
        document.getElementById('persona-details').appendChild(overlay);

        // Mostrar el spinner de carga
        const spinner = document.createElement('div');
        spinner.classList.add('spinner'); // Usar la clase existente
        overlay.appendChild(spinner);

        // Optimizar la imagen antes de subirla
        optimizeImage(file)
            .then(optimizedFile => {
                const formData = new FormData();
                formData.append('file', optimizedFile);


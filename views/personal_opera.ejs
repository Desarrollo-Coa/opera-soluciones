        // Función para optimizar la imagen (puedes usar una librería como pica.js o simplemente ajustar la resolución y calidad)
        function optimizeImage(file) {
            return new Promise((resolve, reject) => {
                const img = new Image();
                const reader = new FileReader();

                reader.onload = function (e) {
                    img.onload = function () {
                        const canvas = document.createElement('canvas');
                        const ctx = canvas.getContext('2d');

                        const maxWidth = 800; // Max width of the image
                        const maxHeight = 800; // Max height of the image

                        let width = img.width;
                        let height = img.height;

                        // Resizing image to fit within max width/height
                        if (width > height) {
                            if (width > maxWidth) {
                                height = height * (maxWidth / width);
                                width = maxWidth;
                            }
                        } else {
                            if (height > maxHeight) {
                                width = width * (maxHeight / height);
                                height = maxHeight;
                            }
                        }

                        canvas.width = width;
                        canvas.height = height;
                        ctx.drawImage(img, 0, 0, width, height);

                        canvas.toBlob(function (blob) {
                            resolve(blob); // Returning the optimized image as blob
                        }, 'image/jpeg', 0.8); // Adjust the quality as needed
                    };

                    img.src = e.target.result;
                };

                reader.onerror = function (error) {
                    reject(error);
                };

                reader.readAsDataURL(file);
            });
        }


            /* Fuente más moderna */
        }

        .panel h2 {
            text-align: center;
            color: #333;
        }




        .fade-in {
            animation: fadeIn 0.5s ease-in-out;
            /* Animación de entrada */
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }


        label {
            font-weight: bold;
            color: #555;
        }

        input[type="text"],
        input[type="email"],
        input[type="date"],
        input[type="file"] {
            width: 100%;
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 6px;
            transition: border-color 0.3s;
        }

        input[type="text"]:focus,
        input[type="email"]:focus,
        input[type="date"]:focus {
            border-color: #007bff;
            /* Color al enfocar */
        }

        button {
            background-color: #007bff;
            /* Color azul */
            color: white;
            border: none;
            border-radius: 6px;
            padding: 10px 15px;
            cursor: pointer;
            transition: background-color 0.3s;
            width: 100%;
        }

        button:hover {
            background-color: #0056b3;
            /* Color más oscuro al pasar el mouse */
        }

        .buttons-dad {
            display: flex;
            justify-content: space-between;
            margin-top: 20px;
        }

        #delete-persona,
        #view-docs-button {
            background-color: #dc3545;
            /* Rojo para eliminar */
            padding: 10px 15px;
        }

        #delete-persona:hover,
        #view-docs-button:hover {
            background-color: #c82333;
            /* Color más oscuro al pasar el mouse */
        }

        .inputreadonly {
            background-color: #f8f9fa;
            /* Fondo gris claro para campos de solo lectura */
            user-select: none;
        }
        /* Para pantallas pequeñas (móviles) */
@media (max-width: 600px) {
    .content-carnet-photo {
        flex-direction: column;
        gap: 20px;

let isDownloadingDocument = false;

// Función para descargar un documento
function descargarDocumento(url, nombreDocumento) {
    // Comprobar si ya se está descargando un documento
    if (isDownloadingDocument) {
        return; // Si ya se está descargando, no hacer nada
    }

    // Bloquear la interfaz mientras se descarga el documento
    isDownloadingDocument = true; // Establecer el estado de descarga
    disableForm(true); // Deshabilitar el formulario

    // Mostrar la superposición para oscurecer la interfaz
    const overlay = document.createElement('div');
    overlay.classList.add('overlay');
    document.body.appendChild(overlay); // Agregar la superposición al body

    // Mostrar el spinner de carga
    const spinner = document.createElement('div');
    spinner.classList.add('spinner'); // Usar la clase existente
    overlay.appendChild(spinner);

    // Hacer una solicitud a la API para obtener el archivo
    fetch(url)
        .then(response => {
            // Verificar si la respuesta es exitosa (código 200)
            if (!response.ok) {
                throw new Error('Error al obtener el archivo');
            }

            // Si es exitosa, obtener el archivo como Blob
            return response.blob();  // Esto nos da el archivo como un objeto binario (Blob)
        })
        .then(blob => {
            // Crear un enlace temporal para descargar el archivo
            const enlace = document.createElement('a');

            // Crear una URL para el archivo Blob
            const urlBlob = URL.createObjectURL(blob);

            // Asignar el Blob URL a href
            enlace.href = urlBlob;

            // Si proporcionamos un nombre para el archivo, lo usamos
            if (nombreDocumento) {
                enlace.download = nombreDocumento;  // Establecer el nombre para la descarga
            }

            // Asegurarse de que el enlace sea accesible (necesario para algunos navegadores)
            enlace.style.display = 'none';
            document.body.appendChild(enlace);

            // Simular el clic en el enlace para iniciar la descarga
            enlace.click();

            // Limpiar el enlace del DOM y revocar la URL Blob
            document.body.removeChild(enlace);
            URL.revokeObjectURL(urlBlob);  // Liberar la URL Blob
        })
        .catch(error => {
            console.error('Error en la descarga: ', error);
            swal('Hubo un error al intentar descargar el archivo.');
        })
        .finally(() => {
            // Restablecer el estado de descarga y ocultar el spinner
            isDownloadingDocument = false; // Restablecer el estado de descarga
            disableForm(false); // Habilitar el formulario
            overlay.remove(); // Eliminar la superposición
        });
}


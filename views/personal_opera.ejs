<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Personal Opera</title>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>



    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        /* Estilo para la superposición que oscurece la interfaz */
.overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5); /* Fondo oscuro semi-transparente */
    z-index: 999; /* Asegúrate de que esté por encima de otros elementos */
}

/* Estilo para el spinner de carga */
.spinner {
    border: 4px solid rgba(255, 255, 255, 0.3);
    border-radius: 50%;
    border-top: 4px solid #3498db; /* Color del borde superior */
    width: 30px; /* Tamaño del spinner */
    height: 30px; /* Tamaño del spinner */
    animation: spin 1s linear infinite; /* Animación de rotación */
    position: absolute;
    top: 50%; /* Centrar verticalmente */
    left: 50%; /* Centrar horizontalmente */
    transform: translate(-50%, -50%); /* Ajustar para centrar */
}

/* Animación de rotación */
@keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

        .download-button,
        .delete-button {
            width: 120px;
        }

        .content-carnet-photo {
            display: flex;
            gap: 40px;
        }

        img {
            height: 250px;
            width: 250px;
            border-radius: 6px;
        }

        .fade-in {

            height: 250px;
            width: 250px;
            margin-bottom: 10px;
        }

        .modal-content ul li {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }


        .modal-content ul li span {
            display: flex;
            gap: 5px;
        }



        .foto-content-dad {
            display: flex;
            flex-direction: column;
            align-items: start;
            margin-bottom: 20px;
        }

        .modal-content ul li {
            display: flex;
        }

        /* Estilo para los modales */
        .modal {
            display: none;
            position: fixed;
            z-index: 1;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            overflow: auto;
            background-color: rgba(0, 0, 0, 0.4);
            padding-top: 60px;
        }

        .form-group {
            display: flex;
            justify-content: space-between;
            width: 240px;
            gap: 10px;
            margin-bottom: 10px;
            border-bottom: 1px solid black;
            font-size: 12px;
            padding-bottom: 5px;
        }

        .form-group input {
            border: 2px solid #444;
            height: 2.5em;
            display: flex;
            padding-left: 0.8em;
            outline: none;
            border-radius: 10px;
            transition: all 0.5s;
            background-color: white;

        }

        #foto-upload-form input,
        #foto-upload-form button {
            width: 120px
        }

        .form-registrar-personal {
            display: flex;
            gap: 20px;
        }

        .modal-content {
            display: flex;
            background: #f2f2f2;
            margin: 5% auto;
            padding: 20px;
            border: 1px solid #888;
            width: 120em;
            border-radius: 12px;
            max-width: 700px;
            flex-direction: column;
        }

        .close {
            color: #333;
            font-size: 28px;
            font-weight: bold;
            float: right;
            width: 40px;
        }

        .close:hover,
        .close:focus {
            color: black;
            text-decoration: none;
            cursor: pointer;
        }

        .inputreadonly {
            opacity: 0;
        }


        .buttons-dad {
            display: flex;
            gap: 10px;
        }

        body {
            display: flex;
            background-color: #333;
        }

        .container {
            display: flex;
            background-color: #fff;
            height: 80vh;
            margin: 20px;
            width: 300px;
            justify-content: center;
            border-radius: 12px;
            padding: 30px 0px;
            overflow-y: scroll;
            scrollbar-width: none;

            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.268);

        }

        #btnAbrirModal {
            position: absolute;
            bottom: 10px;
            left: 10px;
        }

        .left-panel {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        #edit-form {
            display: flex;
            gap: 20px;
        }

        #edit-form input {
            border: 2px solid #444;
            height: 2em;
            padding-left: 0.8em;
            outline: none;
            width: 80%;
            border-radius: 10px;
            transition: all 0.5s;
            background-color: #f9f9f9;
        }

        #edit-form input:hover,
        #edit-form input:focus {
            border: 2px solid #333;
            background-color: white;
        }

        .left-panel ul {
            flex-direction: column;
            display: flex;
            gap: 10px;
            cursor: pointer;
        }


        #btnAbrirModal,
        button {
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: inherit;
            color: #fff;
            background-color: #007bff;
            border: none;
            width: 200px;
            padding: 12px 16px;
            font-size: inherit;
            gap: 8px;
            margin: 12px 0;
            cursor: pointer;
            border-radius: 6px;
            box-shadow: 0px 0px 3px rgba(0, 0, 0, 0.1), 0px 2px 3px rgba(0, 0, 0, 0.2);
        }

        .left-panel ul li {
            padding: 7px;
            padding-right: 5px;
            list-style: none;
            width: 100%;
            border-top-left-radius: 6px;
            border-bottom-left-radius: 6px;
            transition: background-color 0.2s;
        }

        .left-panel ul li:hover {
            background-color: #333;
            color: #fff;
        }

        button {
            background-color: #444;
        }


        .right-panel {
            background: #ffffff;
            /* Fondo blanco para el carnet */
            margin: 20px;
            border-radius: 12px;
            padding: 30px;
            display: flex;
            flex-direction: column;
            width: auto;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
            /* Sombra sutil */
